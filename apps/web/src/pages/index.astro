---
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Angband Town Online</title>
    <style>
      :root {
        --bg: #11161f;
        --panel: #1a2230;
        --panel-2: #243146;
        --text: #e6edf7;
        --muted: #9eb0ca;
        --accent: #d6a84f;
        --grid: #0d1219;
        --player: #7ee787;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        background:
          radial-gradient(circle at top, rgba(214, 168, 79, 0.14), transparent 25%),
          linear-gradient(180deg, #0f141c 0%, #11161f 100%);
        color: var(--text);
      }

      main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 24px;
      }

      h1 {
        margin-top: 0;
        letter-spacing: 0.04em;
      }

      .layout {
        display: grid;
        grid-template-columns: 320px 1fr 320px;
        gap: 16px;
      }

      .panel {
        background: rgba(26, 34, 48, 0.92);
        border: 1px solid rgba(214, 168, 79, 0.18);
        border-radius: 16px;
        padding: 16px;
        box-shadow: 0 16px 40px rgba(0, 0, 0, 0.24);
      }

      .stack {
        display: grid;
        gap: 12px;
      }

      label {
        display: grid;
        gap: 6px;
        color: var(--muted);
        font-size: 0.92rem;
      }

      input,
      button,
      select {
        width: 100%;
        padding: 10px 12px;
        border-radius: 10px;
        border: 1px solid rgba(214, 168, 79, 0.2);
        background: #0f1622;
        color: var(--text);
      }

      button {
        cursor: pointer;
        background: linear-gradient(180deg, #d6a84f, #b07f23);
        color: #17110a;
        font-weight: 700;
      }

      .town-grid {
        display: grid;
        grid-template-columns: repeat(20, 1fr);
        gap: 2px;
        background: var(--grid);
        padding: 8px;
        border-radius: 12px;
      }

      .cell {
        aspect-ratio: 1;
        display: grid;
        place-items: center;
        font-size: 0.85rem;
        border-radius: 6px;
        background: rgba(255, 255, 255, 0.03);
        color: var(--muted);
      }

      .cell.player {
        background: rgba(126, 231, 135, 0.18);
        color: var(--player);
        font-weight: 700;
      }

      .presence-list,
      .chat-log {
        display: grid;
        gap: 8px;
        max-height: 420px;
        overflow: auto;
      }

      .presence-item,
      .chat-item {
        padding: 10px 12px;
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.04);
      }

      .muted {
        color: var(--muted);
      }

      .controls {
        display: grid;
        grid-template-columns: repeat(3, 42px);
        gap: 6px;
        justify-content: center;
      }

      .inline-actions {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 8px;
      }

      .move-key {
        padding: 6px 0;
        min-height: 42px;
        display: grid;
        place-items: center;
        font-size: 0.9rem;
        line-height: 1.05;
      }

      .move-key small {
        display: block;
        font-size: 0.68rem;
        font-weight: 600;
      }

      @media (max-width: 980px) {
        .layout {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Angband Town Online</h1>
      <p class="muted">Prototype v1: login stub, shared town presence, and live town chat.</p>

      <div class="layout">
        <section class="panel stack">
          <h2>Account</h2>
          <label>
            Account Name
            <input id="account-name" value="JoshuaAccount" maxlength="32" />
          </label>
          <button id="load-account-button">Load Account</button>
          <p id="connection-status" class="muted">Disconnected</p>

          <h2>Character</h2>
          <label>
            Character
            <select id="character-select"></select>
          </label>
          <label>
            New Character
            <input id="new-character-name" maxlength="24" placeholder="Create a new adventurer..." />
          </label>
          <button id="create-character-button">Create Character</button>
          <button id="login-button">Enter Town</button>

          <h2>Movement</h2>
          <div class="controls">
            <button class="move-key" data-direction="northwest" data-key="7">↖<small>7</small></button>
            <button class="move-key" data-direction="north" data-key="8">↑<small>8</small></button>
            <button class="move-key" data-direction="northeast" data-key="9">↗<small>9</small></button>
            <button class="move-key" data-direction="west" data-key="4">←<small>4</small></button>
            <button class="move-key" disabled>•<small>5</small></button>
            <button class="move-key" data-direction="east" data-key="6">→<small>6</small></button>
            <button class="move-key" data-direction="southwest" data-key="1">↙<small>1</small></button>
            <button class="move-key" data-direction="south" data-key="2">↓<small>2</small></button>
            <button class="move-key" data-direction="southeast" data-key="3">↘<small>3</small></button>
          </div>
          <p class="muted">Use numpad or number keys: `7 8 9 / 4 6 / 1 2 3`.</p>
        </section>

        <section class="panel stack">
          <h2>Town</h2>
          <div id="town-grid" class="town-grid"></div>
        </section>

        <section class="panel stack">
          <h2>Party</h2>
          <div id="party-summary" class="presence-list"></div>
          <label>
            Party Name
            <input id="party-name" maxlength="32" placeholder="Dungeon Party" />
          </label>
          <button id="create-party-button">Create Party</button>
          <label>
            Join Party ID
            <input id="join-party-id" maxlength="64" placeholder="party_..." />
          </label>
          <button id="join-party-button">Join Party</button>
          <button id="leave-party-button">Leave Party</button>

          <h2>Dungeon Run</h2>
          <div id="instance-summary" class="presence-list"></div>
          <button id="launch-solo-button">Launch Solo Run</button>
          <button id="launch-party-button">Launch Party Run</button>
          <button id="return-town-button">Return To Town</button>
          <div class="inline-actions">
            <button id="use-up-stairs-button">Use &gt;</button>
            <button id="use-down-stairs-button">Use &lt;</button>
          </div>

          <h2>Players</h2>
          <div id="presence-list" class="presence-list"></div>

          <h2>Town Chat</h2>
          <div id="chat-log" class="chat-log"></div>
          <label>
            Message
            <input id="chat-input" maxlength="280" placeholder="Say something to town..." />
          </label>
          <button id="chat-send">Send</button>
        </section>
      </div>
    </main>

    <script>
      import "../scripts/town-client.js";
    </script>
  </body>
</html>
