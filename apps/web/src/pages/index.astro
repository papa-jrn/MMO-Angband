---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Angband Town Online</title>
    <style>
      .panel-shell {
        background: var(--panel);
        border: 1px solid var(--panel-border);
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.38);
      }

      .muted {
        color: var(--muted);
      }

      .summary-card,
      .presence-item,
      .chat-item,
      .inventory-row,
      .party-card {
        border: 1px solid rgba(212, 175, 95, 0.14);
        background: rgba(255, 248, 220, 0.04);
      }

      .town-grid {
        position: relative;
        display: grid;
        grid-template-columns: repeat(var(--grid-width, 20), 1.08rem);
        grid-auto-rows: 1.08rem;
        gap: 0;
        width: max-content;
        padding: 10px;
        border-radius: 18px;
        border: 1px solid rgba(212, 175, 95, 0.18);
        background:
          radial-gradient(circle at top, rgba(212, 175, 95, 0.12), transparent 28%),
          rgba(8, 7, 5, 0.86);
        overflow: hidden;
      }

      .cell {
        display: grid;
        place-items: center;
        width: 1.08rem;
        height: 1.08rem;
        border-radius: 0;
        background: transparent;
        color: var(--muted);
        font-family: "IBM Plex Mono", monospace;
        font-size: 0.8rem;
        font-weight: 400;
        line-height: 1;
      }

      .cell.player {
        background: rgba(250, 204, 21, 0.12);
        color: var(--caution);
        border: 1px solid rgba(250, 204, 21, 0.2);
      }

      .cell.player.player-active-turn {
        background: rgba(134, 239, 172, 0.22);
        color: var(--active);
        border: 1px solid rgba(134, 239, 172, 0.5);
        box-shadow: inset 0 0 0 1px rgba(134, 239, 172, 0.15), 0 0 14px rgba(134, 239, 172, 0.35);
        text-shadow: 0 0 14px rgba(134, 239, 172, 0.8);
      }

      .cell.player.player-waiting-turn {
        background: rgba(250, 204, 21, 0.18);
        color: var(--caution);
        border: 1px solid rgba(250, 204, 21, 0.34);
        box-shadow: inset 0 0 0 1px rgba(250, 204, 21, 0.08), 0 0 10px rgba(250, 204, 21, 0.2);
        text-shadow: 0 0 12px rgba(250, 204, 21, 0.55);
      }

      .cell.monster {
        color: #fca5a5;
      }

      .cell.item {
        color: #93c5fd;
      }

      .presence-list,
      .chat-log,
      .inventory-list,
      .summary-list,
      .dungeon-feed {
        display: grid;
        gap: 8px;
        max-height: 290px;
        overflow: auto;
      }

      .summary-card,
      .presence-item,
      .chat-item,
      .inventory-row,
      .party-card,
      button {
        overflow-wrap: anywhere;
      }

      .projectile-layer {
        position: absolute;
        inset: 10px;
        pointer-events: none;
      }

      .control-button {
        width: calc(95%);
        min-width: 0;
        max-width: calc(95%);
        white-space: normal;
        word-break: break-word;
        margin-right: auto;
      }

      .projectile {
        position: absolute;
        width: 14px;
        height: 14px;
        display: grid;
        place-items: center;
        color: var(--gold);
        font-size: 0.95rem;
        line-height: 1;
        filter: drop-shadow(0 0 10px rgba(212, 175, 95, 0.7));
        transform: translate(-50%, -50%);
        animation: projectile-flight 0.9s linear forwards;
      }

      @keyframes projectile-flight {
        0% {
          opacity: 0;
        }
        10% {
          opacity: 1;
        }
        85% {
          opacity: 1;
        }
        100% {
          opacity: 0;
        }
      }

      .modal-shell {
        position: fixed;
        inset: 0;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 24px;
        background: rgba(5, 4, 3, 0.78);
        backdrop-filter: blur(8px);
        z-index: 20;
      }

      .modal-shell[data-open="true"] {
        display: flex;
      }
    </style>
  </head>
  <body>
    <main class="mx-auto max-w-[1520px] px-4 py-5 md:px-6">
      <header class="mb-6 rounded-3xl border border-[rgba(212,175,95,0.2)] bg-[rgba(17,14,10,0.74)] px-5 py-4 shadow-2xl backdrop-blur-sm">
        <h1 class="text-3xl font-normal tracking-[0.22em] text-[var(--gold)] md:text-4xl">Angband Town Online</h1>
        <p class="mt-2 max-w-3xl text-sm muted md:text-base">Shared dungeon runs, party combat, and live town chat in a multiplayer Angband-inspired prototype.</p>
      </header>

      <div class="grid gap-4 xl:grid-cols-[360px_minmax(0,1fr)_300px]">
        <section class="panel-shell min-w-0 grid gap-4 rounded-3xl p-4 backdrop-blur-sm">
          <div class="grid gap-2">
            <h2 class="text-lg tracking-[0.18em] text-[var(--gold)] uppercase">Account</h2>
            <label class="grid gap-2 text-sm muted">
              Account Name
              <input id="account-name" value="JoshuaAccount" maxlength="32" class="control-button rounded-xl border border-[rgba(212,175,95,0.18)] bg-[rgba(15,12,9,0.9)] px-3 py-2 text-[var(--text)]" />
            </label>
            <button id="load-account-button" class="control-button rounded-xl bg-amber-300/90 px-3 py-2 text-sm font-medium text-stone-950 transition hover:bg-amber-200">Load Account</button>
            <p id="connection-status" class="text-sm muted">Disconnected</p>
          </div>

          <div class="grid gap-3">
            <h2 class="text-lg tracking-[0.18em] text-[var(--gold)] uppercase">Character</h2>
            <label class="grid gap-2 text-sm muted">
              Character
              <select id="character-select" class="control-button rounded-xl border border-[rgba(212,175,95,0.18)] bg-[rgba(15,12,9,0.9)] px-3 py-2 text-[var(--text)]"></select>
            </label>
            <div class="grid gap-2">
              <button id="open-character-modal-button" class="control-button rounded-xl bg-stone-800 px-3 py-2 text-sm text-[var(--text)] ring-1 ring-[rgba(212,175,95,0.18)] transition hover:bg-stone-700">Create Character</button>
              <button id="login-button" class="control-button rounded-xl bg-amber-300/90 px-3 py-2 text-sm font-medium text-stone-950 transition hover:bg-amber-200">Enter Town</button>
            </div>
            <button id="open-party-modal-button" class="control-button rounded-xl bg-red-950/80 px-3 py-2 text-sm text-[var(--text)] ring-1 ring-[rgba(212,175,95,0.18)] transition hover:bg-red-900/80">Party</button>
            <div id="selected-character-summary" class="summary-list"></div>
          </div>

          <div class="grid gap-3">
            <h2 class="text-lg tracking-[0.18em] text-[var(--gold)] uppercase">Inventory</h2>
            <div id="inventory-list" class="inventory-list"></div>
          </div>

          <div class="grid gap-3">
            <h2 class="text-lg tracking-[0.18em] text-[var(--gold)] uppercase">Equipment</h2>
            <div id="equipment-list" class="inventory-list"></div>
          </div>

          <div class="grid gap-3">
            <h2 class="text-lg tracking-[0.18em] text-[var(--gold)] uppercase">Magic</h2>
            <div id="spell-list" class="inventory-list"></div>
          </div>
        </section>

        <section class="panel-shell min-w-0 grid gap-4 rounded-3xl p-4 backdrop-blur-sm">
          <div class="flex items-center justify-between gap-[10px]">
            <button id="launch-solo-button" class="h-12 min-w-0 flex-1 rounded-xl bg-amber-300/90 px-3 text-sm font-medium text-stone-950 transition hover:bg-amber-200">Launch Solo Run</button>
            <button id="return-town-button" class="h-12 min-w-0 flex-1 rounded-xl bg-stone-800 px-3 text-sm text-[var(--text)] ring-1 ring-[rgba(212,175,95,0.18)] transition hover:bg-stone-700">Return To Town</button>
          </div>

          <div class="grid gap-3">
            <div class="flex items-center justify-between gap-3">
              <h2 class="text-lg tracking-[0.18em] text-[var(--gold)] uppercase">Town / Dungeon</h2>
            </div>
            <div id="map-viewport" class="mx-auto h-[42rem] max-w-full overflow-auto rounded-2xl border border-[rgba(212,175,95,0.14)] bg-[rgba(5,4,3,0.16)]">
              <div class="relative w-max">
                <div class="town-grid" id="town-grid"></div>
                <div id="projectile-layer" class="projectile-layer"></div>
              </div>
            </div>
          </div>

          <div class="grid gap-3">
            <h2 class="text-lg tracking-[0.18em] text-[var(--gold)] uppercase">Town Chat</h2>
            <div id="chat-log" class="chat-log"></div>
            <div class="grid gap-2 md:grid-cols-[1fr_auto] md:items-end">
              <label class="grid gap-2 text-sm muted">
                Message
                <input id="chat-input" maxlength="280" placeholder="Say something to town..." class="rounded-xl border border-[rgba(212,175,95,0.18)] bg-[rgba(15,12,9,0.9)] px-3 py-2 text-[var(--text)]" />
              </label>
              <button id="chat-send" class="rounded-xl bg-amber-300/90 px-4 py-2 text-sm font-medium text-stone-950 transition hover:bg-amber-200">Send</button>
            </div>
          </div>
        </section>

        <section class="panel-shell min-w-0 grid gap-4 rounded-3xl p-4 backdrop-blur-sm">
          <div class="grid gap-3">
            <h2 class="text-lg tracking-[0.18em] text-[var(--gold)] uppercase">Dungeon Log</h2>
            <div id="instance-summary" class="dungeon-feed"></div>
          </div>

          <div class="grid gap-3">
            <h2 class="text-lg tracking-[0.18em] text-[var(--gold)] uppercase">Party</h2>
            <div id="party-summary" class="presence-list"></div>
          </div>

          <div class="grid gap-3">
            <h2 class="text-lg tracking-[0.18em] text-[var(--gold)] uppercase">Players</h2>
            <div id="presence-list" class="presence-list"></div>
          </div>

          <div class="grid gap-3">
            <h2 class="text-lg tracking-[0.18em] text-[var(--gold)] uppercase">Dungeon Actions</h2>
            <div class="grid gap-2">
              <button id="pickup-item-button" class="rounded-xl bg-stone-800 px-3 py-2 text-sm text-[var(--text)] ring-1 ring-[rgba(212,175,95,0.18)] transition hover:bg-stone-700">Pick Up Item (G)</button>
              <button id="melee-attack-button" class="rounded-xl bg-stone-800 px-3 py-2 text-sm text-[var(--text)] ring-1 ring-[rgba(212,175,95,0.18)] transition hover:bg-stone-700">Melee Attack</button>
              <button id="ranged-attack-button" class="rounded-xl bg-stone-800 px-3 py-2 text-sm text-[var(--text)] ring-1 ring-[rgba(212,175,95,0.18)] transition hover:bg-stone-700">Ranged Attack</button>
              <button id="rest-button" class="rounded-xl bg-stone-800 px-3 py-2 text-sm text-[var(--text)] ring-1 ring-[rgba(212,175,95,0.18)] transition hover:bg-stone-700">Rest 10 Turns (R)</button>
              <div class="grid grid-cols-2 gap-2">
                <button id="use-up-stairs-button" class="rounded-xl bg-stone-800 px-3 py-2 text-sm text-[var(--text)] ring-1 ring-[rgba(212,175,95,0.18)] transition hover:bg-stone-700">Use &gt;</button>
                <button id="use-down-stairs-button" class="rounded-xl bg-stone-800 px-3 py-2 text-sm text-[var(--text)] ring-1 ring-[rgba(212,175,95,0.18)] transition hover:bg-stone-700">Use &lt;</button>
              </div>
            </div>
          </div>

          <div class="grid gap-3">
            <h2 class="text-lg tracking-[0.18em] text-[var(--gold)] uppercase">Movement</h2>
            <div class="grid grid-cols-3 gap-2 justify-center">
              <button class="move-key rounded-xl bg-stone-800 px-2 py-2 text-xs text-[var(--text)] ring-1 ring-[rgba(212,175,95,0.18)] transition hover:bg-stone-700" data-direction="northwest" data-key="7">NW<small>7</small></button>
              <button class="move-key rounded-xl bg-stone-800 px-2 py-2 text-xs text-[var(--text)] ring-1 ring-[rgba(212,175,95,0.18)] transition hover:bg-stone-700" data-direction="north" data-key="8">N<small>8</small></button>
              <button class="move-key rounded-xl bg-stone-800 px-2 py-2 text-xs text-[var(--text)] ring-1 ring-[rgba(212,175,95,0.18)] transition hover:bg-stone-700" data-direction="northeast" data-key="9">NE<small>9</small></button>
              <button class="move-key rounded-xl bg-stone-800 px-2 py-2 text-xs text-[var(--text)] ring-1 ring-[rgba(212,175,95,0.18)] transition hover:bg-stone-700" data-direction="west" data-key="4">W<small>4</small></button>
              <button class="move-key rounded-xl bg-stone-950 px-2 py-2 text-xs text-[var(--muted)] ring-1 ring-[rgba(212,175,95,0.14)]" disabled>.<small>5</small></button>
              <button class="move-key rounded-xl bg-stone-800 px-2 py-2 text-xs text-[var(--text)] ring-1 ring-[rgba(212,175,95,0.18)] transition hover:bg-stone-700" data-direction="east" data-key="6">E<small>6</small></button>
              <button class="move-key rounded-xl bg-stone-800 px-2 py-2 text-xs text-[var(--text)] ring-1 ring-[rgba(212,175,95,0.18)] transition hover:bg-stone-700" data-direction="southwest" data-key="1">SW<small>1</small></button>
              <button class="move-key rounded-xl bg-stone-800 px-2 py-2 text-xs text-[var(--text)] ring-1 ring-[rgba(212,175,95,0.18)] transition hover:bg-stone-700" data-direction="south" data-key="2">S<small>2</small></button>
              <button class="move-key rounded-xl bg-stone-800 px-2 py-2 text-xs text-[var(--text)] ring-1 ring-[rgba(212,175,95,0.18)] transition hover:bg-stone-700" data-direction="southeast" data-key="3">SE<small>3</small></button>
            </div>
            <p class="text-xs muted">Use numpad or number keys: `7 8 9 / 4 6 / 1 2 3`.</p>
          </div>
        </section>
      </div>
    </main>

    <div id="character-modal" class="modal-shell" data-open="false">
      <section class="panel-shell grid w-full max-w-4xl gap-4 rounded-3xl p-5" aria-modal="true" role="dialog" aria-labelledby="character-modal-title">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h2 id="character-modal-title" class="text-xl tracking-[0.18em] text-[var(--gold)] uppercase">Create Character</h2>
            <p class="mt-2 text-sm muted">Build your adventurer with Angband-inspired race and class data plus a 35-point buy.</p>
          </div>
          <button id="close-character-modal-button" class="rounded-xl bg-stone-800 px-3 py-2 text-sm text-[var(--text)] ring-1 ring-[rgba(212,175,95,0.18)]">Close</button>
        </div>

        <label class="grid gap-2 text-sm muted">
          New Character
          <input id="new-character-name" maxlength="24" placeholder="Create a new adventurer..." class="rounded-xl border border-[rgba(212,175,95,0.18)] bg-[rgba(15,12,9,0.9)] px-3 py-2 text-[var(--text)]" />
        </label>
        <div class="grid gap-3 md:grid-cols-2">
          <label class="grid gap-2 text-sm muted">
            Race
            <select id="race-select" class="rounded-xl border border-[rgba(212,175,95,0.18)] bg-[rgba(15,12,9,0.9)] px-3 py-2 text-[var(--text)]"></select>
          </label>
          <label class="grid gap-2 text-sm muted">
            Class
            <select id="class-select" class="rounded-xl border border-[rgba(212,175,95,0.18)] bg-[rgba(15,12,9,0.9)] px-3 py-2 text-[var(--text)]"></select>
          </label>
        </div>

        <div class="grid gap-3 xl:grid-cols-[280px_minmax(0,1fr)]">
          <div id="point-buy-summary" class="summary-card rounded-2xl px-4 py-3 text-sm muted"></div>
          <div class="grid gap-2">
            <label class="grid grid-cols-[48px_92px_1fr] items-center gap-2 text-sm muted">
              <span class="text-[var(--gold)]">STR</span>
              <input id="stat-strength" type="number" min="8" max="15" step="1" value="8" class="rounded-xl border border-[rgba(212,175,95,0.18)] bg-[rgba(15,12,9,0.9)] px-3 py-2 text-[var(--text)]" />
              <small id="final-strength"></small>
            </label>
            <label class="grid grid-cols-[48px_92px_1fr] items-center gap-2 text-sm muted">
              <span class="text-[var(--gold)]">INT</span>
              <input id="stat-intelligence" type="number" min="8" max="15" step="1" value="8" class="rounded-xl border border-[rgba(212,175,95,0.18)] bg-[rgba(15,12,9,0.9)] px-3 py-2 text-[var(--text)]" />
              <small id="final-intelligence"></small>
            </label>
            <label class="grid grid-cols-[48px_92px_1fr] items-center gap-2 text-sm muted">
              <span class="text-[var(--gold)]">WIS</span>
              <input id="stat-wisdom" type="number" min="8" max="15" step="1" value="8" class="rounded-xl border border-[rgba(212,175,95,0.18)] bg-[rgba(15,12,9,0.9)] px-3 py-2 text-[var(--text)]" />
              <small id="final-wisdom"></small>
            </label>
            <label class="grid grid-cols-[48px_92px_1fr] items-center gap-2 text-sm muted">
              <span class="text-[var(--gold)]">DEX</span>
              <input id="stat-dexterity" type="number" min="8" max="15" step="1" value="8" class="rounded-xl border border-[rgba(212,175,95,0.18)] bg-[rgba(15,12,9,0.9)] px-3 py-2 text-[var(--text)]" />
              <small id="final-dexterity"></small>
            </label>
            <label class="grid grid-cols-[48px_92px_1fr] items-center gap-2 text-sm muted">
              <span class="text-[var(--gold)]">CON</span>
              <input id="stat-constitution" type="number" min="8" max="15" step="1" value="8" class="rounded-xl border border-[rgba(212,175,95,0.18)] bg-[rgba(15,12,9,0.9)] px-3 py-2 text-[var(--text)]" />
              <small id="final-constitution"></small>
            </label>
          </div>
        </div>

        <div id="creation-summary" class="summary-list"></div>
        <button id="create-character-button" class="rounded-xl bg-amber-300/90 px-3 py-2 text-sm font-medium text-stone-950 transition hover:bg-amber-200">Create Character</button>
      </section>
    </div>

    <div id="party-modal" class="modal-shell" data-open="false">
      <section class="panel-shell grid w-full max-w-4xl gap-4 rounded-3xl p-5" aria-modal="true" role="dialog" aria-labelledby="party-modal-title">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h2 id="party-modal-title" class="text-xl tracking-[0.18em] text-[var(--gold)] uppercase">Party</h2>
            <p class="mt-2 text-sm muted">Create, join, or launch a party run from one place.</p>
          </div>
          <button id="close-party-modal-button" class="rounded-xl bg-stone-800 px-3 py-2 text-sm text-[var(--text)] ring-1 ring-[rgba(212,175,95,0.18)]">Close</button>
        </div>

        <div id="party-modal-summary" class="presence-list"></div>

        <div class="grid gap-3 md:grid-cols-2">
          <section class="party-card grid gap-3 rounded-2xl p-4">
            <h3 class="text-sm uppercase tracking-[0.18em] text-[var(--gold)]">Create A Party</h3>
            <label class="grid gap-2 text-sm muted">
              Party Name
              <input id="party-name" maxlength="32" placeholder="Dungeon Party" class="rounded-xl border border-[rgba(212,175,95,0.18)] bg-[rgba(15,12,9,0.9)] px-3 py-2 text-[var(--text)]" />
            </label>
            <button id="create-party-button" class="rounded-xl bg-amber-300/90 px-3 py-2 text-sm font-medium text-stone-950 transition hover:bg-amber-200">Create Party</button>
          </section>

          <section class="party-card grid gap-3 rounded-2xl p-4">
            <h3 class="text-sm uppercase tracking-[0.18em] text-[var(--gold)]">Join A Party</h3>
            <label class="grid gap-2 text-sm muted">
              Join Party ID
              <input id="join-party-id" maxlength="64" placeholder="party_..." class="rounded-xl border border-[rgba(212,175,95,0.18)] bg-[rgba(15,12,9,0.9)] px-3 py-2 text-[var(--text)]" />
            </label>
            <button id="join-party-button" class="rounded-xl bg-stone-800 px-3 py-2 text-sm text-[var(--text)] ring-1 ring-[rgba(212,175,95,0.18)] transition hover:bg-stone-700">Join Party</button>
          </section>
        </div>

        <section class="party-card grid gap-3 rounded-2xl p-4">
          <h3 class="text-sm uppercase tracking-[0.18em] text-[var(--gold)]">Party Actions</h3>
          <p class="text-sm muted">Launch the shared run once your group is ready.</p>
          <div class="grid gap-2 md:grid-cols-2">
            <button id="launch-party-button" class="rounded-xl bg-amber-300/90 px-3 py-2 text-sm font-medium text-stone-950 transition hover:bg-amber-200">Launch Party Run</button>
            <button id="leave-party-button" class="rounded-xl bg-stone-800 px-3 py-2 text-sm text-[var(--text)] ring-1 ring-[rgba(212,175,95,0.18)] transition hover:bg-stone-700">Leave Party</button>
          </div>
        </section>
      </section>
    </div>

    <script>
      import "../scripts/town-client.js";
    </script>
  </body>
</html>
